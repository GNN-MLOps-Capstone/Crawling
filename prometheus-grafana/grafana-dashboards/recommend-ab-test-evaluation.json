    {
      "id": 9,
      "type": "timeseries",
      "title": "CTR by Variant",
      "description": "Uses recommendation_serves experiment_id/variant with source fallback for historical rows.",
      "datasource": {
        "type": "postgres",
        "uid": "news-postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "news-postgres"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH impressions AS (\n  SELECT $__timeGroupAlias(rs.created_at, $__interval), COALESCE(NULLIF(rs.variant, ''), CASE WHEN rs.source LIKE 'ab_latest_%' THEN 'latest' WHEN rs.source LIKE 'ab_popular_%' THEN 'popular' WHEN rs.source LIKE 'ab_random_%' THEN 'random' ELSE 'recommend' END) AS metric, rs.request_id, rs.user_id, (item ->> 'news_id')::bigint AS news_id\n  FROM public.recommendation_serves rs\n  CROSS JOIN LATERAL jsonb_array_elements(rs.served_items) AS item\n  WHERE $__timeFilter(rs.created_at) AND (COALESCE(NULLIF(rs.variant, ''), CASE WHEN rs.source LIKE 'ab_latest_%' THEN 'latest' WHEN rs.source LIKE 'ab_popular_%' THEN 'popular' WHEN rs.source LIKE 'ab_random_%' THEN 'random' ELSE 'recommend' END)) IN (${variant:sqlstring})\n    AND COALESCE(NULLIF(rs.experiment_id, ''), 'control') IN (${db_experiment:sqlstring})\n    AND rs.request_id IS NOT NULL AND item ? 'news_id' AND (item ->> 'news_id') ~ '^[0-9]+$'\n), clicks AS (\n  SELECT DISTINCT ie.request_id, ie.user_id, ie.news_id\n  FROM public.interaction_events ie\n  WHERE $__timeFilter(ie.event_ts_server) AND ie.event_type = 'content_open' AND ie.request_id IS NOT NULL AND ie.news_id IS NOT NULL\n)\nSELECT time, metric, COUNT(c.news_id)::double precision / NULLIF(COUNT(*), 0) AS value\nFROM impressions i\nLEFT JOIN clicks c ON c.request_id = i.request_id AND c.user_id = i.user_id AND c.news_id = i.news_id\nGROUP BY time, metric\nORDER BY time;",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "barAlignment": 0,
            "lineWidth": 1,
            "fillOpacity": 8,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "",
            "axisColorMode": "text",
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Hit@5 by Variant",
      "description": "",
      "datasource": {
        "type": "postgres",
        "uid": "news-postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "news-postgres"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH impressions AS (\n  SELECT $__timeGroupAlias(rs.created_at, $__interval), COALESCE(NULLIF(rs.variant, ''), CASE WHEN rs.source LIKE 'ab_latest_%' THEN 'latest' WHEN rs.source LIKE 'ab_popular_%' THEN 'popular' WHEN rs.source LIKE 'ab_random_%' THEN 'random' ELSE 'recommend' END) AS metric, rs.request_id, rs.user_id, (item ->> 'news_id')::bigint AS news_id, COALESCE(NULLIF(item ->> 'position', '')::integer, 2147483647) AS rank\n  FROM public.recommendation_serves rs\n  CROSS JOIN LATERAL jsonb_array_elements(rs.served_items) AS item\n  WHERE $__timeFilter(rs.created_at) AND (COALESCE(NULLIF(rs.variant, ''), CASE WHEN rs.source LIKE 'ab_latest_%' THEN 'latest' WHEN rs.source LIKE 'ab_popular_%' THEN 'popular' WHEN rs.source LIKE 'ab_random_%' THEN 'random' ELSE 'recommend' END)) IN (${variant:sqlstring})\n    AND COALESCE(NULLIF(rs.experiment_id, ''), 'control') IN (${db_experiment:sqlstring})\n    AND rs.request_id IS NOT NULL AND item ? 'news_id' AND (item ->> 'news_id') ~ '^[0-9]+$'\n), sessions AS (\n  SELECT DISTINCT time, metric, request_id, user_id FROM impressions\n), clicks AS (\n  SELECT DISTINCT ie.request_id, ie.user_id, ie.news_id\n  FROM public.interaction_events ie\n  WHERE $__timeFilter(ie.event_ts_server) AND ie.event_type = 'content_open' AND ie.request_id IS NOT NULL AND ie.news_id IS NOT NULL\n), clicked_sessions AS (\n  SELECT DISTINCT i.time, i.metric, i.request_id, i.user_id\n  FROM impressions i\n  JOIN clicks c ON c.request_id = i.request_id AND c.user_id = i.user_id AND c.news_id = i.news_id\n  WHERE i.rank <= 5\n)\nSELECT s.time, s.metric, COUNT(cs.request_id)::double precision / NULLIF(COUNT(*), 0) AS value\nFROM sessions s\nLEFT JOIN clicked_sessions cs ON cs.time = s.time AND cs.metric = s.metric AND cs.request_id = s.request_id AND cs.user_id = s.user_id\nGROUP BY s.time, s.metric\nORDER BY s.time;",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
