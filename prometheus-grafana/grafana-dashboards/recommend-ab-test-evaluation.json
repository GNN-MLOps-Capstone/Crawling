    {
      "id": 14,
      "type": "table",
      "title": "Variant Summary",
      "description": "",
      "datasource": {
        "type": "postgres",
        "uid": "news-postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 31
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "news-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH impressions AS (\n  SELECT COALESCE(NULLIF(rs.variant, ''), CASE WHEN rs.source LIKE 'ab_latest_%' THEN 'latest' WHEN rs.source LIKE 'ab_popular_%' THEN 'popular' WHEN rs.source LIKE 'ab_random_%' THEN 'random' ELSE 'recommend' END) AS variant, rs.request_id, rs.user_id, (item ->> 'news_id')::bigint AS news_id, COALESCE(NULLIF(item ->> 'position', '')::integer, 2147483647) AS rank\n  FROM public.recommendation_serves rs\n  CROSS JOIN LATERAL jsonb_array_elements(rs.served_items) AS item\n  WHERE $__timeFilter(rs.created_at) AND (COALESCE(NULLIF(rs.variant, ''), CASE WHEN rs.source LIKE 'ab_latest_%' THEN 'latest' WHEN rs.source LIKE 'ab_popular_%' THEN 'popular' WHEN rs.source LIKE 'ab_random_%' THEN 'random' ELSE 'recommend' END)) IN (${variant:sqlstring})\n    AND COALESCE(NULLIF(rs.experiment_id, ''), 'control') IN (${db_experiment:sqlstring})\n    AND rs.request_id IS NOT NULL AND item ? 'news_id' AND (item ->> 'news_id') ~ '^[0-9]+$'\n), clicks AS (\n  SELECT DISTINCT ie.request_id, ie.user_id, ie.news_id\n  FROM public.interaction_events ie\n  WHERE $__timeFilter(ie.event_ts_server) AND ie.event_type = 'content_open' AND ie.request_id IS NOT NULL AND ie.news_id IS NOT NULL\n), first_click AS (\n  SELECT i.variant, i.request_id, i.user_id, MIN(i.rank) AS first_clicked_rank\n  FROM impressions i\n  JOIN clicks c ON c.request_id = i.request_id AND c.user_id = i.user_id AND c.news_id = i.news_id\n  GROUP BY i.variant, i.request_id, i.user_id\n), sessions AS (\n  SELECT DISTINCT variant, request_id, user_id FROM impressions\n)\nSELECT i.variant, COUNT(*) AS impressions, COUNT(c.news_id) AS clicks,\n       ROUND(COUNT(c.news_id)::numeric / NULLIF(COUNT(*), 0), 4) AS ctr,\n       ROUND(AVG(CASE WHEN fc.first_clicked_rank IS NULL THEN 0.0 ELSE 1.0 / fc.first_clicked_rank END)::numeric, 4) AS mrr,\n       ROUND(COUNT(DISTINCT CASE WHEN i.rank <= 5 AND c.news_id IS NOT NULL THEN i.request_id || ':' || i.user_id END)::numeric / NULLIF(COUNT(DISTINCT s.request_id || ':' || s.user_id), 0), 4) AS hit_at_5,\n       COUNT(DISTINCT s.request_id || ':' || s.user_id) AS sessions\nFROM impressions i\nLEFT JOIN clicks c ON c.request_id = i.request_id AND c.user_id = i.user_id AND c.news_id = i.news_id\nLEFT JOIN first_click fc ON fc.variant = i.variant AND fc.request_id = i.request_id AND fc.user_id = i.user_id\nLEFT JOIN sessions s ON s.variant = i.variant AND s.request_id = i.request_id AND s.user_id = i.user_id\nGROUP BY i.variant\nORDER BY i.variant;",
          "refId": "A"
        }
