    {
      "id": 11,
      "type": "timeseries",
      "title": "MRR by Variant",
      "description": "",
      "datasource": {
        "type": "postgres",
        "uid": "news-postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
