          "rawQuery": true,
          "rawSql": "SELECT COALESCE(NULLIF(rs.experiment_id, ''), 'control') AS experiment_id, COALESCE(NULLIF(rs.variant, ''), CASE WHEN rs.source LIKE 'ab_latest_%' THEN 'latest' WHEN rs.source LIKE 'ab_popular_%' THEN 'popular' WHEN rs.source LIKE 'ab_random_%' THEN 'random' ELSE 'recommend' END) AS variant, rs.source, COUNT(DISTINCT rs.request_id) AS sessions, SUM(rs.served_count) AS served_items\nFROM public.recommendation_serves rs\nWHERE $__timeFilter(rs.created_at) AND (COALESCE(NULLIF(rs.variant, ''), CASE WHEN rs.source LIKE 'ab_latest_%' THEN 'latest' WHEN rs.source LIKE 'ab_popular_%' THEN 'popular' WHEN rs.source LIKE 'ab_random_%' THEN 'random' ELSE 'recommend' END)) IN (${variant:sqlstring})\n    AND COALESCE(NULLIF(rs.experiment_id, ''), 'control') IN (${db_experiment:sqlstring})\nGROUP BY experiment_id, variant, rs.source\nORDER BY experiment_id, variant, sessions DESC;",
          "refId": "A"
