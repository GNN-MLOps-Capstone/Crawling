{
  "uid": "recommend-api-observability",
  "title": "Recommend API Observability",
  "tags": [
    "recommend",
    "api",
    "ab-test"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "experiment_id",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(recommend_requests_total, experiment_id)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "variant",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(recommend_requests_total{experiment_id=~\"$experiment_id\"}, variant)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(recommend_requests_total{experiment_id=~\"$experiment_id\",variant=~\"$variant\"}[5m])) by (status, experiment_id, variant)",
          "legendFormat": "{{status}} {{experiment_id}}/{{variant}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p95 Latency",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(recommend_request_latency_seconds_bucket{experiment_id=~\"$experiment_id\",variant=~\"$variant\"}[5m])) by (le, experiment_id, variant))",
          "legendFormat": "{{experiment_id}}/{{variant}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Fallback Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(recommend_fallback_total{experiment_id=~\"$experiment_id\",variant=~\"$variant\"}[5m])) by (reason, experiment_id, variant) / clamp_min(sum(rate(recommend_requests_total{status=\"success\",experiment_id=~\"$experiment_id\",variant=~\"$variant\"}[5m])) by (experiment_id, variant), 1)",
          "legendFormat": "{{reason}} {{experiment_id}}/{{variant}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Empty Result Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(recommend_empty_results_total{experiment_id=~\"$experiment_id\",variant=~\"$variant\"}[5m])) by (experiment_id, variant) / clamp_min(sum(rate(recommend_requests_total{status=\"success\",experiment_id=~\"$experiment_id\",variant=~\"$variant\"}[5m])) by (experiment_id, variant), 1)",
          "legendFormat": "{{experiment_id}}/{{variant}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Path Mix",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(recommend_path_items_total{experiment_id=~\"$experiment_id\",variant=~\"$variant\"}[5m])) by (path, experiment_id, variant)",
