        {
          "expr": "sum(rate(recommend_prefetch_events_total{experiment_id=~\"$experiment_id\",variant=~\"$variant\"}[5m])) by (status, trigger_path, experiment_id, variant)",
          "legendFormat": "{{status}}/{{trigger_path}} {{experiment_id}}/{{variant}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
